{
    "name": "on2media/oauth2-sso-client-demo",
    "description": "Demonstration of an OAuth2 single sign-on client",
    "type": "project",
    "keywords": ["on2 media", "oauth2", "sso", "single sign-on", "demo"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "on2media/oauth2-sso-client": "^0.2",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "phpcs-dry": "php-cs-fixer fix --verbose --allow-risky=yes --dry-run --diff",
        "phpcs-fix": "php-cs-fixer fix --verbose --allow-risky=yes"
    }
}
